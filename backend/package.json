{
  "name": "fila-backend",
  "version": "1.0.0",
  "description": "Queue management system backend for barbershops",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "start:api": "node server.api.js",
    "start:worker": "node server.worker.js",
    "start:whatsapp": "node server.whatsapp.js",
    "seed": "node scripts/seed.js",
