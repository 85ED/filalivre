# Minimal Dockerfile for WhatsApp Service Validation
# Purpose: Test if installing system dependencies fixes Puppeteer/Chromium initialization
# Base: Node 22 Alpine (same as production)

FROM node:22-alpine

# Install ONLY the critical system dependencies for Puppeteer/Chromium
# This is the hypothesis test - if service starts and /ping works, 
# then Railway Nixpacks was missing these libraries
# Note: Using Alpine package names (not Ubuntu/Debian)
RUN apk add --no-cache \
  chromium \
  ffmpeg \
  nss \
  freetype \
  harfbuzz \
  ca-certificates \
  ttf-freefont

WORKDIR /app

# Copy only package.json files (minimal)
COPY package*.json ./

# Install npm dependencies
RUN npm ci --only=production

# Copy application code
COPY . .

# Copy environment file
COPY .env .env

# Configure Puppeteer to use system Chromium (not bundled download)
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV CHROME_EXECUTABLE_PATH=/usr/bin/chromium-browser
ENV WHATSAPP_PORT=3003
ENV NODE_ENV=production

EXPOSE 3003

# Start the WhatsApp service directly
CMD ["node", "server.whatsapp.js"]
