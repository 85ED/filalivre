# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=8880
DB_NAME=fila

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development

# WhatsApp Microservice Port (WhatsApp service escuta nesta porta)
WHATSAPP_PORT=3003

# CORS
CORS_ORIGIN=http://localhost:5173

# WhatsApp Service URL (como a API chama o serviço WhatsApp)
# Local development: http://localhost:3003
# Railway production: http://filalivre-whatsapp:3003 (use via Railway variables)
WHATSAPP_SERVICE_URL=http://localhost:3003

# Worker configuration
WORKER_INTERVAL=10000
